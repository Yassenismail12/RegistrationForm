# ── Cloudflare Worker secrets (set via `wrangler secret put`) ─────────────────
TURNSTILE_SECRET=your-cloudflare-turnstile-secret-key

# ── wrangler.toml vars (set directly in wrangler.toml) ───────────────────────
# WORKER_ALLOWED_ORIGIN=https://your-pages-domain.pages.dev
# KV namespace id is set in wrangler.toml [[kv_namespaces]]
